{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Note Desk",
  "version": "0.1.0",
  "identifier": "com.notedesk.local",
  "build": {
    "beforeDevCommand": "npm run dev:client",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Note Desk",
        "label": "main",
        "width": 1120,
        "height": 760,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
